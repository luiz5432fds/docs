# AI Maestro - Environment Variables

# Google API Key for Gemini
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# NotebookLM API (if available)
NOTEBOOKLM_API_KEY=your_notebooklm_api_key
NOTEBOOKLM_PROJECT_ID=your_project_id

# Optional: Anthropic Claude API (alternative LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: OpenAI API (alternative LLM)
OPENAI_API_KEY=your_openai_api_key

# Audio processing
AUDIO_SAMPLE_RATE=22050
AUDIO_CHUNK_SIZE=4096

# RAG settings
FAISS_INDEX_PATH=cerebro_faiss
PDF_LIBRARY_PATH=meus_livros
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Reaper settings
REAPER_EXECUTABLE_PATH=/usr/bin/reaper
REAPER_PROJECT_PATH=projetos

# MuseScore settings
MUSESCORE_EXECUTABLE_PATH=/usr/bin/musescore
MUSESCORE_TEMPLATE_PATH=templates
